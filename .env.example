# .env.example - Example environment variables configuration file

# The API key for accessing external services (e.g., Deep Research Vector)
# DO NOT hardcode your actual API key here. Copy this file to .env and set the value there.
API_KEY=your_api_key_here

# Flask environment (e.g., development, production)
FLASK_ENV=development

# Optional: Flask run port
# PORT=5000
